{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/checker-receipt-v0.json",
  "title": "MathEvidence Checker Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestDigest",
    "bundleDigest",
    "theoremDigest",
    "axiomDigests",
    "capability",
    "checker",
    "claimRequested",
    "claimEstablished",
    "unresolvedObligations",
    "assuranceMode",
    "resultStatus",
    "toolchain"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "receiptDigest": { "$ref": "#/$defs/sha256Digest" },
    "requestDigest": { "$ref": "#/$defs/sha256Digest" },
    "bundleDigest": { "$ref": "#/$defs/sha256Digest" },
    "theoremDigest": { "$ref": "#/$defs/sha256Digest" },
    "axiomDigests": {
      "type": "array",
      "items": { "$ref": "#/$defs/sha256Digest" }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "checker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "module", "name", "version"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "module": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "soundnessTheorem": { "type": "string", "minLength": 1 }
      }
    },
    "claimRequested": { "$ref": "#/$defs/claimClass" },
    "claimEstablished": {
      "anyOf": [{ "$ref": "#/$defs/claimClass" }, { "type": "null" }]
    },
    "unresolvedObligations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assuranceMode": {
      "enum": ["kernel_replay", "verified_reflection", "native_checked"]
    },
    "operationalBase": {
      "type": "object",
      "description": "Required when assuranceMode is native_checked: records the enlarged operational base and the linked small-instance kernel replay.",
      "additionalProperties": false,
      "required": ["enlargedOps", "kernelReplayBundleId"],
      "properties": {
        "enlargedOps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Native/ops declared as trusted for this receipt (never silent)."
        },
        "kernelReplayBundleId": {
          "type": "string",
          "minLength": 1,
          "description": "Opaque id of a deterministic small-instance kernel_replay bundle validating the checker."
        },
        "notes": { "type": "string" }
      }
    },
    "resultStatus": {
      "enum": [
        "computed",
        "tested",
        "witness_verified",
        "soundness_verified",
        "completeness_verified",
        "optimality_verified",
        "approximation_certified",
        "native_verified",
        "rejected",
        "unsupported",
        "ambiguous"
      ]
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["leanVersion", "lakeVersion"],
      "properties": {
        "leanVersion": { "type": "string", "minLength": 1 },
        "lakeVersion": { "type": "string", "minLength": 1 },
        "mathlibVersion": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "detail": { "type": "string" },
    "contentDigest": { "$ref": "#/$defs/sha256Digest" },
    "signatureAlg": {
      "type": "string",
      "enum": ["hmac-sha256", "ed25519"]
    },
    "signatureKeyId": { "type": "string", "minLength": 1 },
    "signature": {
      "type": "string",
      "pattern": "^hex:[0-9a-f]+$"
    }
  },
  "$defs": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "claimClass": {
      "enum": [
        "candidate",
        "witness",
        "refutation",
        "decomposition",
        "soundResult",
        "completeSolution",
        "optimum",
        "enclosure",
        "canonicalForm"
      ]
    }
  }
}
