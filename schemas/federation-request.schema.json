{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/federation-request-v0.json",
  "title": "Federated Capability Request",
  "description": "Solver-independent request envelope for federated capabilities. Payload body remains external-project-owned.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "capabilityId",
    "claimClass",
    "requestDigest",
    "opaqueIr",
    "externalPayload"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "capabilityId": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "claimClass": { "type": "string" },
    "requestDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "opaqueIr": {
      "$ref": "https://mathevidence.org/schemas/federation-opaque-ir-v0.json"
    },
    "externalPayload": {
      "type": "object",
      "description": "Opaque bytes-as-JSON owned by the external project; MathEvidence does not interpret semantics",
      "additionalProperties": true
    },
    "hints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Untrusted search / strategy hints; never advance proof status alone"
    }
  }
}
