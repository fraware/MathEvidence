{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/symbolic-calculus-request-v0.json",
  "title": "algebra.formal_rational_calculus request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "capability",
    "capabilityVersion",
    "operation",
    "variables",
    "independentVar",
    "expr",
    "domainConditions",
    "requestedClaim",
    "resourcePolicy",
    "requestDigest"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "capability": { "type": "string", "const": "algebra.formal_rational_calculus" },
    "capabilityVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "operation": {
      "enum": [
        "derivative_candidate",
        "antiderivative_candidate",
        "recurrence_identity",
        "ode_candidate"
      ]
    },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_']*$",
            "maxLength": 64
          },
          "type": { "type": "string", "const": "Rat" }
        }
      }
    },
    "independentVar": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_']*$"
    },
    "dependentVar": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_']*$"
    },
    "expr": {
      "$ref": "https://mathevidence.org/schemas/rational-expr-v0.json#/$defs/RationalExpr"
    },
    "candidate": {
      "$ref": "https://mathevidence.org/schemas/rational-expr-v0.json#/$defs/RationalExpr"
    },
    "domainConditions": {
      "type": "array",
      "items": {
        "$ref": "https://mathevidence.org/schemas/rational-expr-v0.json#/$defs/RationalExpr"
      }
    },
    "initialConditions": {
      "type": "array",
      "items": {
        "$ref": "https://mathevidence.org/schemas/calculus-expr-v0.json#/$defs/InitialCondition"
      }
    },
    "odeRhs": {
      "$ref": "https://mathevidence.org/schemas/rational-expr-v0.json#/$defs/RationalExpr"
    },
    "recurrenceRhs": {
      "$ref": "https://mathevidence.org/schemas/rational-expr-v0.json#/$defs/RationalExpr"
    },
    "requestedClaim": {
      "enum": ["candidate", "soundResult", "witness"]
    },
    "resourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWallTimeMs": { "type": "integer", "minimum": 1 },
        "maxOutputBytes": { "type": "integer", "minimum": 1 },
        "maxExprNodes": { "type": "integer", "minimum": 1 }
      }
    },
    "requestDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "operation": { "const": "derivative_candidate" } }
      },
      "then": { "required": ["candidate"] }
    },
    {
      "if": {
        "properties": { "operation": { "const": "antiderivative_candidate" } }
      },
      "then": { "required": ["candidate"] }
    },
    {
      "if": {
        "properties": { "operation": { "const": "recurrence_identity" } }
      },
      "then": { "required": ["recurrenceRhs", "dependentVar"] }
    },
    {
      "if": {
        "properties": { "operation": { "const": "ode_candidate" } }
      },
      "then": { "required": ["odeRhs", "dependentVar"] }
    }
  ]
}
