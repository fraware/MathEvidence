{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/ideal-membership-request-v0.json",
  "title": "algebra.groebner_membership request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "capability",
    "capabilityVersion",
    "target",
    "generators",
    "requestDigest"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "capability": { "type": "string", "const": "algebra.groebner_membership" },
    "capabilityVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "target": { "$ref": "#/$defs/sparsePoly" },
    "generators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/sparsePoly" }
    },
    "requestedClaim": {
      "enum": ["candidate", "witness", "soundResult"]
    },
    "requestDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "maxLength": 2048 }
    }
  },
  "$defs": {
    "sparsePoly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["varCount", "terms"],
      "properties": {
        "varCount": { "type": "integer", "minimum": 0, "maximum": 256 },
        "terms": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/term" }
        }
      }
    },
    "term": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coefficient", "exponents"],
      "properties": {
        "coefficient": { "type": "integer" },
        "exponents": {
          "type": "array",
          "maxItems": 256,
          "items": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
