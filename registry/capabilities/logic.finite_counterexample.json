{
  "id": "logic.finite_counterexample",
  "version": "0.1.0",
  "status": "experimental",
  "lifecycle": "experimental",
  "role": "custom_ir_checker",
  "externalSearchEssential": true,
  "implementationLevel": "custom_ir",
  "adoptionLevel": "none",
  "federationLevel": "fixture",
  "domain": "logic.finite_domains",
  "inputIR": {
    "name": "FinitePredicate",
    "schema": "schemas/finite-predicate.schema.json",
    "version": "0.1.0",
    "leanPackage": "MathEvidence.IR.FinitePredicate"
  },
  "admissibility": {
    "summary": "Custom FinitePredicate IR witness against a false conjecture on an explicit finite carrier. Not general Mathlib goal reification yet. Exhaustive absence proofs are out of scope.",
    "rejectedConstructs": [
      "infinite_domain_search",
      "exhaustive_absence_as_completeness",
      "approximate_numeric_witness"
    ],
    "requiredAssumptions": [
      "explicit finite domain",
      "Lean-evaluable original predicate"
    ]
  },
  "claimClasses": [
    "witness",
    "candidate",
    "refutation"
  ],
  "evidenceSchema": "schemas/finite-counterexample-certificate.schema.json",
  "requestSchema": "schemas/finite-counterexample-request.schema.json",
  "checker": {
    "package": "MathEvidence.Checkers.Counterexample",
    "version": "0.1.0",
    "assurance": "kernel_replay",
    "soundnessStatus": "present"
  },
  "assuranceModes": [
    "kernel_replay"
  ],
  "limits": {
    "maxDomainCardinality": 1024,
    "maxWallTimeMs": 60000,
    "maxOutputBytes": 1048576,
    "maxCpuTimeMs": 60000,
    "maxMemoryBytes": 536870912
  },
  "perfBudgets": {
    "maxReifyMs": 500,
    "maxBackendGenerateMs": 8000,
    "maxEvidenceBytes": 524288,
    "maxDecodeMs": 500,
    "maxCheckerMs": 5000,
    "maxMemoryBytes": 536870912,
    "maxLeanBuildMs": 600000
  },
  "knownLimitations": [
    "Does not prove that no counterexample exists.",
    "Adapter enumeration is untrusted; Lean Counterexample checker owns acceptance.",
    "Mathematica live_generator_complete when wolframscript live mode is enabled (CI fixture otherwise); search is bounded enumeration.",
    "Sage live_generator_complete when sage is available (CI fixture otherwise)."
  ],
  "conformance": {
    "suite": "evidence/conformance/finite_counterexample",
    "status": "passing",
    "requiredCases": [
      "simple_false_universal",
      "witness_type_mismatch",
      "hash_mismatch",
      "out_of_domain_rejected"
    ]
  },
  "maintainers": [
    {
      "name": "MathEvidence core",
      "role": "capability_owner",
      "contact": "see SUPPORT.md"
    }
  ],
  "supportClaims": {
    "declared": true,
    "installedHint": "Lean MathEvidence.IR.FinitePredicate + MathEvidence.Checkers.Counterexample; Agent thin compute: sympy only until registry-driven dispatch lands",
