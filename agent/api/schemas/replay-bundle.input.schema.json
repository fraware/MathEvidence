{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/agent-replay-bundle-input-v0.json",
  "title": "replay_bundle input",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundleId"],
  "properties": {
    "bundleId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Opaque Agent bundle identifier. Raw filesystem paths are not accepted on the public Agent API."
    }
  }
}
