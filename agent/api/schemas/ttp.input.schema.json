{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/agent-ttp-input-v0.json",
  "title": "Trace-to-Plan Agent input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "workspaceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "goal": {
      "type": "string",
      "description": "Optional human-readable goal label; never upgrades epistemic status."
    }
  }
}
