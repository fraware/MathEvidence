{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/agent-open-bundle-input-v0.json",
  "title": "open_bundle / inspect_bundle input",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundleId"],
  "properties": {
    "bundleId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Opaque Agent bundle identifier (content-addressed sha256_* or agent store id). Raw filesystem paths are not accepted."
    }
  }
}
