{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathevidence.org/schemas/corpus-release-v0.json",
  "title": "Foundry corpus release package",
  "description": "Release manifest for a public certified tool-use corpus slice. Training releases MUST disclose tier composition and contamination controls.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseId",
    "version",
    "license",
    "acceptanceInfluence",
    "tierComposition",
    "splits",
    "episodes",
    "datasheet",
    "knownBiases"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "releaseId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "title": { "type": "string", "maxLength": 256 },
    "description": { "type": "string", "maxLength": 4096 },
    "license": { "type": "string", "minLength": 1, "maxLength": 128 },
    "acceptanceInfluence": {
      "type": "boolean",
      "const": false
    },
    "createdAt": { "type": "string", "maxLength": 64 },
    "sourceCommit": { "type": "string", "maxLength": 128 },
    "tierComposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Q0_raw",
        "Q1_schema_valid",
        "Q2_formally_verified",
        "Q3_semantically_reviewed",
        "Q4_library_grade"
      ],
      "properties": {
        "Q0_raw": { "type": "integer", "minimum": 0 },
        "Q1_schema_valid": { "type": "integer", "minimum": 0 },
        "Q2_formally_verified": { "type": "integer", "minimum": 0 },
        "Q3_semantically_reviewed": { "type": "integer", "minimum": 0 },
        "Q4_library_grade": { "type": "integer", "minimum": 0 }
      }
    },
    "splits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["immutable", "train", "eval", "held_out"],
      "properties": {
        "immutable": {
          "type": "boolean",
          "const": true,
          "description": "Benchmark / eval splits MUST NOT be reshuffled after release."
        },
        "policy": {
          "type": "string",
          "maxLength": 64,
          "description": "Split assignment policy (e.g. source_family)."
        },
        "train": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 100000
        },
        "eval": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 100000
        },
        "held_out": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 100000
        },
        "bySourceFamily": {
          "type": "object",
          "description": "Per source-family counts in train/eval/held_out.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "episodes": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1024 },
      "minItems": 1,
      "maxItems": 100000
    },
    "benchmarkExclusions": {
      "type": "array",
      "items": { "type": "string", "maxLength": 512 },
      "maxItems": 100000
    },
    "datasheet": { "type": "string", "maxLength": 1024 },
    "knownBiases": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1024 },
      "minItems": 1,
      "maxItems": 64
    },
    "contaminationSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duplicateCount": { "type": "integer", "minimum": 0 },
        "inPublicLibraryCount": { "type": "integer", "minimum": 0 },
        "syntheticNegativeCount": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string", "maxLength": 4096 }
      }
    }
  }
}
